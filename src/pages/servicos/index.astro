---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const allServicos = await getCollection('servicos');
const servicos = allServicos.sort((a, b) => (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0));

const title = "Serviços | Aluguel de Betoneira - Todos os Modelos";
const description = "Conheça nossas betoneiras para locação: 120L, 150L, 200L e 400L. Equipamentos revisados com entrega rápida e preço justo.";
---

<Layout title={title} description={description} canonical="/servicos">
  <Header currentPath="/servicos" />

  <main>
    <!-- Hero Section -->
    <section class="relative py-32 lg:py-40 bg-secondary overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=1200&auto=format&fit=crop"
          srcset="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=640&auto=format&fit=crop 640w, https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=960&auto=format&fit=crop 960w, https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=1200&auto=format&fit=crop 1200w"
          sizes="100vw"
          alt=""
          class="h-full w-full object-cover blur-md"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1280"
        />
        <div class="absolute inset-0 bg-secondary/70"></div>
      </div>

      <div class="relative container mx-auto px-6 sm:px-8 lg:px-12">
        <h1 class="text-6xl sm:text-7xl lg:text-8xl font-black text-white leading-[1.05] mb-12 max-w-4xl">
          Nossos Serviços
        </h1>
        <p class="text-2xl sm:text-3xl text-gray-100 max-w-3xl leading-relaxed">
          Oferecemos betoneiras de diversas capacidades para atender projetos de todos os tamanhos. Todos os equipamentos são revisados antes da entrega.
        </p>
      </div>
    </section>

    <!-- Services Grid -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {servicos.map((servico) => (
            <article class="group relative rounded-2xl border border-gray-200 bg-white p-10 shadow-sm transition-all hover:shadow-lg hover:-translate-y-1 hover:scale-[1.02]">
              <div class="flex items-start justify-between mb-6">
                <div class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary text-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                </div>
                <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-secondary ring-1 ring-inset ring-primary/20">
                  {servico.data.capacidade}
                </span>
              </div>

              <h2 class="text-2xl font-bold text-gray-900 mb-3">{servico.data.title}</h2>

              <p class="text-base text-gray-600 mb-8">
                {servico.data.description}
              </p>

              <div class="flex flex-col sm:flex-row gap-3">
                <a
                  href={`/servicos/${servico.slug}`}
                  class="inline-flex items-center justify-center rounded-full bg-secondary px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-secondary/30 hover:bg-secondary-700 hover:scale-105 active:scale-95 transition-all"
                >
                  Ver Detalhes
                </a>
                <a
                  href="/contato"
                  class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-bold text-accent shadow-lg shadow-primary/20 hover:bg-primary-400 hover:scale-105 active:scale-95 transition-all"
                >
                  Solicitar Orçamento
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
