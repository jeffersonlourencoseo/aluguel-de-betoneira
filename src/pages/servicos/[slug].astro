---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_CONFIG } from '../../data/config';

export async function getStaticPaths() {
  const servicos = await getCollection('servicos');
  return servicos.map((servico) => ({
    params: { slug: servico.slug },
    props: { servico },
  }));
}

const { servico } = Astro.props;
const { Content } = await servico.render();

const title = `${servico.data.title} | Aluguel de Betoneira`;
const description = servico.data.description;
const keywords = servico.data.keywords;

const pageUrl = `${SITE_CONFIG.url}/servicos/${servico.slug}/`;
const imageUrl = `${SITE_CONFIG.url}${servico.data.image || '/images/og-image.svg'}`;

const skuMap = {
  'betoneira-120l': 'BTN-120L',
  'betoneira-150l': 'BTN-150L',
  'betoneira-200l': 'BTN-200L',
  'betoneira-400l': 'BTN-400L',
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  '@id': `${pageUrl}#product`,
  name: servico.data.title,
  description: servico.data.description,
  url: pageUrl,
  image: imageUrl,
  sku: skuMap[servico.slug] || servico.slug,
  brand: {
    '@type': 'Brand',
    name: SITE_CONFIG.name,
  },
  additionalProperty: [
    {
      '@type': 'PropertyValue',
      name: 'Capacidade',
      value: servico.data.capacidade,
    },
    {
      '@type': 'PropertyValue',
      name: 'Motor',
      value: servico.data.motor,
    },
    {
      '@type': 'PropertyValue',
      name: 'Peso',
      value: servico.data.peso,
    },
  ],
  offers: {
    '@context': 'https://schema.org',
    '@type': 'Offer',
    '@id': `${pageUrl}#offer`,
    url: pageUrl,
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
    businessFunction: 'http://purl.org/goodrelations/v1#LeaseOut',
    areaServed: {
      '@type': 'Place',
      name: SITE_CONFIG.areaServed,
    },
    seller: {
      '@type': 'LocalBusiness',
      '@id': `${SITE_CONFIG.url}/#localbusiness`,
    },
    priceValidUntil: '2026-12-31',
  },
};

const faqData = {
  'betoneira-120l': [
    { name: 'Quanto custa alugar uma betoneira 120 litros?', text: 'O valor da diária para betoneira 120 litros começa a partir de R$ 80,00, com descontos para locações semanais e mensais.' },
    { name: 'Para qual tipo de obra a betoneira 120 litros é indicada?', text: 'Ela é ideal para pequenas reformas, construções residenciais simples, calçadas e muros de arrimo.' },
    { name: 'A betoneira 120 litros inclui motor?', text: 'Sim, todas as betoneiras são entregues com motor funcionando perfeitamente e garantia durante a locação.' },
    { name: 'Qual o prazo mínimo de locação?', text: 'O prazo mínimo é de 1 dia. Oferecemos descontos especiais para locações semanais e mensais.' },
  ],
  'betoneira-150l': [
    { name: 'Quanto custa alugar uma betoneira 150 litros?', text: 'O valor da diária para betoneira 150 litros começa a partir de R$ 100,00, com descontos para locações semanais e mensais.' },
    { name: 'Qual a diferença entre betoneira 120L e 150L?', text: 'A betoneira 150 litros tem maior capacidade de mistura e produção, sendo ideal para obras residenciais de médio porte e reformas comerciais.' },
    { name: 'A entrega está incluída no valor da locação?', text: 'O frete de entrega e retirada é calculado por distância e informado no orçamento. Região Norte do Rio tem frete reduzido.' },
    { name: 'Posso trocar de modelo durante a locação?', text: 'Sim, é possível fazer upgrade para modelos maiores durante a locação, pagando apenas a diferença proporcional.' },
  ],
  'betoneira-200l': [
    { name: 'Quanto custa alugar uma betoneira 200 litros?', text: 'O valor da diária para betoneira 200 litros começa a partir de R$ 130,00, com descontos para locações semanais e mensais.' },
    { name: 'Para qual tipo de obra a betoneira 200 litros é indicada?', text: 'Ela é ideal para construções residenciais de grande porte, reformas extensas e pequenos empreendimentos comerciais.' },
    { name: 'Qual a produção diária da betoneira 200 litros?', text: 'A betoneira 200 litros produz até 7 m³ de concreto por dia, com motor de 2 CV.' },
    { name: 'É melhor alugar duas 150L ou uma 200L?', text: 'Para um único ponto de concreto, a betoneira 200 litros é mais econômica e prática de operar.' },
  ],
  'betoneira-400l': [
    { name: 'Quanto custa alugar uma betoneira 400 litros?', text: 'O valor da diária para betoneira 400 litros começa a partir de R$ 250,00, com descontos para locações semanais e mensais.' },
    { name: 'Para qual tipo de obra a betoneira 400 litros é indicada?', text: 'Ela é ideal para construções comerciais, usinas de concreto temporárias, grandes reformas e empreendimentos de grande porte.' },
    { name: 'Qual a produção diária da betoneira 400 litros?', text: 'A betoneira 400 litros produz até 10 m³ de concreto por dia, com capacidade de mistura de ~260 litros.' },
    { name: 'É melhor alugar uma 400L ou duas de 200L?', text: 'Se a obra tem um único ponto de concreto, a betoneira 400 litros é mais econômica. Para dois pontos distantes, duas de 200L podem fazer sentido.' },
  ],
};

const faqSchema = faqData[servico.slug]
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqData[servico.slug].map((q) => ({
        '@type': 'Question',
        name: q.name,
        acceptedAnswer: {
          '@type': 'Answer',
          text: q.text,
        },
      })),
    }
  : null;
---

<Layout title={title} description={description} keywords={keywords} canonical={`/servicos/${servico.slug}/`} schema={productSchema} breadcrumbName={servico.data.title} preloadHero={false}>
  <Header currentPath="/servicos" />

  {
    faqSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )
  }

  <main>
    <!-- HERO DO SERVIÇO -->
    <section class="relative py-24 lg:py-32 bg-gray-900 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/hero-blur-1200.jpg"
          srcset="/images/hero-blur-640.jpg 640w, /images/hero-blur-960.jpg 960w, /images/hero-blur-1200.jpg 1200w"
          sizes="100vw"
          alt="Betoneira em obra de construção civil no Rio de Janeiro"
          class="h-full w-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1200"
          height="800"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-[#1A1A1A]/90 via-[#2D2D2D]/85 to-[#4A4A4A]/75"></div>
      </div>

      <div class="relative container mx-auto px-6 sm:px-8 lg:px-12 max-w-5xl">
        <div class="flex items-center gap-3 text-sm text-gray-100 mb-6">
          <a href="/servicos/" class="hover:text-primary transition-colors">Serviços</a>
          <span>/</span>
          <span class="text-white">{servico.data.title}</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-16">
          {servico.data.title}
        </h1>

        <p class="text-lg text-gray-100 max-w-2xl mb-10">
          {servico.data.description}
        </p>

        <div class="flex flex-wrap gap-4">
          <span class="inline-flex items-center rounded-full bg-primary/10 px-4 py-2 text-sm font-medium text-primary ring-1 ring-inset ring-primary/20">
            Capacidade: {servico.data.capacidade}
          </span>
          <span class="inline-flex items-center rounded-full bg-white/10 px-4 py-2 text-sm font-medium text-white ring-1 ring-inset ring-white/20">
            Motor: {servico.data.motor}
          </span>
          <span class="inline-flex items-center rounded-full bg-white/10 px-4 py-2 text-sm font-medium text-white ring-1 ring-inset ring-white/20">
            Peso: {servico.data.peso}
          </span>
        </div>
      </div>
    </section>

    <!-- ESPECIFICAÇÕES + BENEFÍCIOS + CTA -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12 max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <div class="lg:col-span-2">
            <!-- Especificações Técnicas -->
            <div class="mb-16">
              <h3 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-8">
                Ficha Técnica Resumida
              </h3>

              <div class="rounded-2xl border border-gray-200 section-concrete overflow-hidden">
                <div class="grid grid-cols-1 sm:grid-cols-2">
                  <div class="p-6 border-b sm:border-b-0 sm:border-r border-gray-200 transition-all hover:bg-gray-100">
                    <p class="text-sm text-gray-500 mb-1">Capacidade do Tambor</p>
                    <p class="text-lg font-bold text-gray-900">{servico.data.capacidade}</p>
                  </div>
                  <div class="p-6 border-b border-gray-200 transition-all hover:bg-gray-100">
                    <p class="text-sm text-gray-500 mb-1">Motor</p>
                    <p class="text-lg font-bold text-gray-900">{servico.data.motor}</p>
                  </div>
                  <div class="p-6 border-b sm:border-b-0 sm:border-r border-gray-200 transition-all hover:bg-gray-100">
                    <p class="text-sm text-gray-500 mb-1">Peso Aproximado</p>
                    <p class="text-lg font-bold text-gray-900">{servico.data.peso}</p>
                  </div>
                  <div class="p-6 transition-all hover:bg-gray-100">
                    <p class="text-sm text-gray-500 mb-1">Garantia</p>
                    <p class="text-lg font-bold text-gray-900">Durante toda a locação</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Conteúdo -->
            <div class="mb-16">
              <article class="prose prose-lg prose-gray max-w-none">
                <Content />
              </article>
            </div>

            <!-- Benefícios -->
            <div class="mb-16">
              <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-8">
                Benefícios da Locação
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div class="flex items-start gap-4 p-6 rounded-xl section-concrete transition-all hover:shadow-md hover:scale-[1.02] reveal">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/20 text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900">Sem investimento alto</h4>
                    <p class="text-sm text-gray-600">Alugue pelo tempo que precisar sem comprar o equipamento.</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-6 rounded-xl section-concrete transition-all hover:shadow-md hover:scale-[1.02] reveal">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/20 text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900">Manutenção zero</h4>
                    <p class="text-sm text-gray-600">Nós cuidamos da revisão. Você só usa.</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-6 rounded-xl section-concrete transition-all hover:shadow-md hover:scale-[1.02] reveal">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/20 text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900">Entrega rápida</h4>
                    <p class="text-sm text-gray-600">Receba no mesmo dia em toda a região.</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-6 rounded-xl section-concrete transition-all hover:shadow-md hover:scale-[1.02] reveal">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/20 text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 13l4 4L19 7"/></svg>
                  </div>
                  <div>
                    <h4 class="font-semibold text-gray-900">Suporte técnico</h4>
                    <p class="text-sm text-gray-600">Atendimento prioritário durante a locação.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Sidebar Preços + CTA -->
          <div class="lg:col-span-1">
            <div class="sticky top-24 space-y-6">
              <div class="rounded-2xl border border-gray-200 section-concrete p-10 transition-all hover:shadow-lg">
                <h3 class="text-xl font-bold text-gray-900 mb-6">Solicite um Orçamento</h3>
                <p class="text-gray-600 mb-8">Entre em contato para receber valores atualizados e condições especiais para o seu projeto.</p>

                <a
                  href="/contato/"
                  class="block w-full text-center rounded-full bg-secondary px-6 py-4 text-base font-bold text-white shadow-lg shadow-secondary/30 hover:bg-secondary-700 hover:scale-105 active:scale-95 transition-all mb-4"
                >
                  Solicitar Orçamento
                </a>

                <a
                  href="https://wa.me/5521997751577?text=Ol%C3%A1%2C%20achei%20voc%C3%AAs%20no%20google%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es!"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-full text-center rounded-full bg-whatsapp px-6 py-4 text-base font-bold text-white shadow-lg shadow-whatsapp/30 hover:bg-whatsapp-dark hover:scale-105 active:scale-95 transition-all"
                >
                  Falar no WhatsApp
                </a>

                <p class="mt-6 text-sm text-gray-500 text-center">
                  Entrega e retirada na cidade do Rio de Janeiro.
                </p>
              </div>

              <!-- CTA Extra -->
              <div class="rounded-2xl bg-secondary p-10 text-center transition-all hover:shadow-lg hover:scale-[1.02]">
                <h4 class="text-lg font-bold text-white mb-3">Não sabe qual escolher?</h4>
                <p class="text-gray-100 text-sm mb-6">Nossa equipe ajuda a escolher o equipamento ideal para sua obra.</p>
                <a
                  href="tel:+5521997751577"
                  class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-bold text-secondary hover:bg-gray-100 hover:scale-105 active:scale-95 transition-all shadow-lg"
                >
                  Ligar Agora
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
