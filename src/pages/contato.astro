---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Contato | Aluguel de Betoneira - Solicite seu Orçamento";
const description = "Entre em contato para alugar betoneira. Solicite orçamento grátis por WhatsApp, telefone ou formulário. Atendimento rápido em toda a região.";

const phone = "(21) 99775-1577";
const phoneRaw = "5521997751577";
const email = "contato@alugueldebetoneira.com.br";
const address = "Av. Brasil, 11201 - Penha Circular, Rio de Janeiro - RJ, 21012-351";
---

<Layout title={title} description={description} canonical="/contato">
  <Header currentPath="/contato" />

  <main>
    <!-- HERO -->
    <section class="relative py-32 lg:py-40 bg-secondary overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=1920&auto=format&fit=crop&fm=webp"
          alt=""
          class="h-full w-full object-cover blur-sm scale-110"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1280"
        />
        <div class="absolute inset-0 bg-secondary/70"></div>
      </div>

      <div class="relative container mx-auto px-6 sm:px-8 lg:px-12">
        <h1 class="text-6xl sm:text-7xl lg:text-8xl font-black text-white leading-[1.05] mb-12 max-w-4xl">
          Entre em Contato
        </h1>
        <p class="text-2xl sm:text-3xl text-gray-100 max-w-3xl leading-relaxed">
          Solicite um orçamento grátis ou tire suas dúvidas. Nossa equipe responde em poucos minutos pelo WhatsApp.
        </p>
      </div>
    </section>

    <!-- NAP + FORM -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
          <!-- NAP e Info -->
          <div class="space-y-10">
            <div>
              <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-4">
                Fale Conosco
              </h2>
              <p class="text-xl text-gray-600">
                Escolha a forma mais conveniente. Nosso atendimento é rápido e humanizado.
              </p>
            </div>

            <!-- WhatsApp CTA Grande -->
            <a
              href={`https://wa.me/${phoneRaw}?text=Ol%C3%A1%2C%20vim%20do%20site%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es!`}
              target="_blank"
              rel="noopener noreferrer"
              class="block rounded-2xl bg-green-600 p-10 text-white hover:bg-green-700 transition-all shadow-xl hover:scale-[1.02] active:scale-95"
            >
              <div class="flex items-center gap-4 mb-4">
                <svg class="h-12 w-12" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                <div>
                  <h3 class="text-xl font-bold">WhatsApp</h3>
                  <p class="text-green-100">Resposta em minutos</p>
                </div>
              </div>
              <p class="text-lg">{phone}</p>
            </a>

            <div class="space-y-6">
              <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 transition-all hover:shadow-md hover:scale-[1.01]">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/20 text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-gray-900">Telefone</h3>
                  <p class="text-gray-600">{phone}</p>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 transition-all hover:shadow-md hover:scale-[1.01]">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/20 text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-gray-900">E-mail</h3>
                  <p class="text-gray-600">{email}</p>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 transition-all hover:shadow-md hover:scale-[1.01]">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/20 text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-gray-900">Endereço</h3>
                  <p class="text-gray-600">{address}</p>
                </div>
              </div>

              <div class="flex items-start gap-4 p-4 rounded-xl bg-gray-50 transition-all hover:shadow-md hover:scale-[1.01]">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/20 text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                  <h3 class="text-base font-semibold text-gray-900">Horário de Atendimento</h3>
                  <p class="text-gray-600">Segunda a Sexta: 07h às 18h</p>
                  <p class="text-gray-600">Sábado: 08h às 12h</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Formulário -->
          <div class="rounded-2xl border border-gray-200 bg-gray-50 p-10">
            <h3 class="text-2xl font-bold text-gray-900 mb-2">Solicitar Orçamento</h3>
            <p class="text-gray-600 mb-8">Preencha o formulário e receba seu orçamento em minutos.</p>

            <form id="form-contato" class="space-y-6">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="nome" class="block text-sm font-medium text-gray-700 mb-2">Nome completo *</label>
                  <input
                    type="text"
                    id="nome"
                    name="nome"
                    required
                    class="block w-full rounded-xl border border-gray-300 bg-white px-5 py-4 text-gray-900 placeholder-gray-400 focus:border-secondary focus:ring-secondary transition-all"
                    placeholder="Seu nome"
                  />
                </div>
                <div>
                  <label for="telefone" class="block text-sm font-medium text-gray-700 mb-2">Telefone / WhatsApp *</label>
                  <input
                    type="tel"
                    id="telefone"
                    name="telefone"
                    required
                    class="block w-full rounded-xl border border-gray-300 bg-white px-5 py-4 text-gray-900 placeholder-gray-400 focus:border-secondary focus:ring-secondary transition-all"
                    placeholder="(21) 99775-1577"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">E-mail</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  class="block w-full rounded-xl border border-gray-300 bg-white px-5 py-4 text-gray-900 placeholder-gray-400 focus:border-secondary focus:ring-secondary transition-all"
                  placeholder="seu@email.com"
                />
              </div>

              <div>
                <label for="servico" class="block text-sm font-medium text-gray-700 mb-2">Equipamento de interesse</label>
                <select
                  id="servico"
                  name="servico"
                  class="block w-full rounded-xl border border-gray-300 bg-white px-5 py-4 text-gray-900 focus:border-secondary focus:ring-secondary transition-all"
                >
                  <option value="">Selecione uma opção</option>
                  <option value="betoneira-120l">Betoneira 120L</option>
                  <option value="betoneira-150l">Betoneira 150L</option>
                  <option value="betoneira-200l">Betoneira 200L</option>
                  <option value="betoneira-400l">Betoneira 400L</option>
                  <option value="nao-sei">Não sei qual escolher</option>
                </select>
              </div>

              <div>
                <label for="mensagem" class="block text-sm font-medium text-gray-700 mb-2">Mensagem</label>
                <textarea
                  id="mensagem"
                  name="mensagem"
                  rows="4"
                  class="block w-full rounded-xl border border-gray-300 bg-white px-5 py-4 text-gray-900 placeholder-gray-400 focus:border-secondary focus:ring-secondary transition-all"
                  placeholder="Descreva sua obra, prazo e qualquer dúvida..."
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full inline-flex items-center justify-center rounded-full bg-secondary px-8 py-5 text-base font-bold text-white shadow-xl shadow-secondary/30 hover:bg-secondary-700 hover:scale-105 active:scale-95 transition-all"
              >
                Enviar Solicitação
                <svg class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script>
    const form = document.getElementById('form-contato');
    if (form) {
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        const nomeEl = form.querySelector('input[name="nome"]');
        const telefoneEl = form.querySelector('input[name="telefone"]');
        const emailEl = form.querySelector('input[name="email"]');
        const servicoEl = form.querySelector('select[name="servico"]');
        const mensagemEl = form.querySelector('textarea[name="mensagem"]');

        const nome = (nomeEl instanceof HTMLInputElement ? nomeEl.value : '').trim();
        const telefone = (telefoneEl instanceof HTMLInputElement ? telefoneEl.value : '').trim();
        const email = (emailEl instanceof HTMLInputElement ? emailEl.value : '').trim();
        const servico = (servicoEl instanceof HTMLSelectElement ? servicoEl.value : '');
        const mensagem = (mensagemEl instanceof HTMLTextAreaElement ? mensagemEl.value : '').trim();

        let texto = 'Olá, achei vocês no google e gostaria de mais informações!';
        texto += '%0A%0A*Nome:* ' + encodeURIComponent(nome);
        texto += '%0A*Telefone:* ' + encodeURIComponent(telefone);
        if (email) texto += '%0A*E-mail:* ' + encodeURIComponent(email);
        if (servico) {
          const labels = {
            'betoneira-120l': 'Betoneira 120L',
            'betoneira-150l': 'Betoneira 150L',
            'betoneira-200l': 'Betoneira 200L',
            'betoneira-400l': 'Betoneira 400L',
            'nao-sei': 'Não sei qual escolher'
          } as Record<string, string>;
          texto += '%0A*Equipamento:* ' + encodeURIComponent(labels[servico] || servico);
        }
        if (mensagem) texto += '%0A%0A*Mensagem:* ' + encodeURIComponent(mensagem);

        window.open('https://wa.me/5521997751577?text=' + texto, '_blank');
      });
    }
  </script>

  <Footer />
</Layout>
