---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.filter((post) => !post.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Blog | Aluguel de Betoneira - Dicas e Guias";
const description = "Confira dicas, guias e novidades sobre locação de betoneiras, construção civil e manutenção de equipamentos.";
---

<Layout title={title} description={description} canonical="/blog">
  <Header currentPath="/blog" />

  <main>
    <!-- Hero Section -->
    <section class="py-24 lg:py-32 bg-secondary">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-16 max-w-3xl">
          Blog
        </h1>
        <p class="text-lg text-gray-100 max-w-2xl">
          Dicas, guias e novidades sobre locação de betoneiras e construção civil.
        </p>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {posts.map((post) => (
            <article class="group flex flex-col rounded-2xl border border-gray-200 bg-white overflow-hidden shadow-sm transition-all hover:shadow-lg hover:-translate-y-1 hover:scale-[1.02]">
              <a href={`/blog/${post.slug}`} class="flex flex-col h-full">
                <div class="aspect-[16/9] bg-gray-200">
                  <div class="flex h-full w-full items-center justify-center bg-gray-800 text-gray-400">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                </div>
                <div class="flex flex-col flex-1 p-10">
                  <div class="flex items-center gap-3 text-sm text-gray-500 mb-4">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                    </time>
                    <span class="text-gray-300">•</span>
                    <span>{post.data.author}</span>
                  </div>
                  <h2 class="text-xl font-bold text-gray-900 group-hover:text-secondary transition-colors mb-3">
                    {post.data.title}
                  </h2>
                  <p class="text-base text-gray-600 flex-1">
                    {post.data.description}
                  </p>
                  <div class="mt-6 inline-flex items-center text-sm font-semibold text-secondary group-hover:text-secondary-700 transition-colors">
                    Ler mais →
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
