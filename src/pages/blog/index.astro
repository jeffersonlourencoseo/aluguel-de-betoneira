---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.filter((post) => !post.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Extrair todas as tags únicas
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))];

const title = "Blog | Aluguel de Betoneira - Dicas e Guias";
const description = "Confira dicas, guias e novidades sobre locação de betoneiras, construção civil e manutenção de equipamentos.";
---

<Layout title={title} description={description} canonical="/blog">
  <Header currentPath="/blog" />

  <main>
    <!-- Hero Section -->
    <section class="relative py-32 lg:py-40 bg-secondary overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?q=80&w=1200&auto=format&fit=crop"
          alt=""
          class="h-full w-full object-cover blur-md"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1920"
          height="1280"
        />
        <div class="absolute inset-0 bg-secondary/70"></div>
      </div>

      <div class="relative container mx-auto px-6 sm:px-8 lg:px-12">
        <h1 class="text-6xl sm:text-7xl lg:text-8xl font-black text-white leading-[1.05] mb-12 max-w-4xl">
          Blog
        </h1>
        <p class="text-2xl sm:text-3xl text-gray-100 max-w-3xl leading-relaxed">
          Dicas, guias e novidades sobre locação de betoneiras e construção civil. Tudo para sua obra sair perfeita.
        </p>
      </div>
    </section>

    <!-- Categorias -->
    <section class="py-16 lg:py-20 bg-gray-50 border-b border-gray-200">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <div class="flex flex-wrap items-center gap-4">
          <span class="text-lg font-bold text-gray-900">Categorias:</span>
          <a href="/blog" class="inline-flex items-center rounded-full bg-secondary px-5 py-2.5 text-base font-semibold text-white hover:bg-secondary-700 transition-all hover:scale-105">
            Todos
          </a>
          {allTags.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-white px-5 py-2.5 text-base font-medium text-gray-700 border border-gray-200 hover:border-secondary hover:text-secondary transition-all hover:scale-105 cursor-default">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Posts Grid -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <div class="flex items-center justify-between mb-16">
          <h2 class="text-4xl sm:text-5xl font-bold text-gray-900">
            Últimos Artigos
          </h2>
          <span class="text-lg text-gray-500">
            {posts.length} artigos publicados
          </span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
          {posts.map((post) => (
            <article class="group flex flex-col rounded-2xl border border-gray-200 bg-white overflow-hidden shadow-sm transition-all hover:shadow-lg hover:-translate-y-1 hover:scale-[1.02]">
              <a href={`/blog/${post.slug}`} class="flex flex-col h-full">
                <div class="aspect-[16/9] bg-gray-200 overflow-hidden">
                  {post.data.image ? (
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  ) : (
                    <div class="flex h-full w-full items-center justify-center bg-gray-800 text-gray-300">
                      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <polyline points="21 15 16 10 5 21"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="flex flex-col flex-1 p-10">
                  <div class="flex items-center gap-3 text-base text-gray-500 mb-4">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                    </time>
                    <span class="text-gray-300">•</span>
                    <span>{post.data.author}</span>
                  </div>
                  <h2 class="text-2xl font-bold text-gray-900 group-hover:text-secondary transition-colors mb-4">
                    {post.data.title}
                  </h2>
                  <p class="text-lg text-gray-600 flex-1 leading-relaxed">
                    {post.data.description}
                  </p>
                  <div class="mt-6 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="inline-flex items-center rounded-full bg-gray-100 px-3 py-1 text-sm font-medium text-gray-600">
                        #{tag}
                      </span>
                    ))}
                  </div>
                  <div class="mt-6 inline-flex items-center text-base font-semibold text-secondary group-hover:text-secondary-700 transition-colors">
                    Ler mais →
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Newsletter / CTA -->
    <section class="py-24 lg:py-32 bg-secondary">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
              Quer receber mais dicas?
            </h2>
            <p class="text-xl text-gray-100 leading-relaxed max-w-xl">
              Entre em contato pelo WhatsApp e receba conteúdo exclusivo sobre construção civil, cuidados com equipamentos e novidades do setor.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-5">
            <a
              href="https://wa.me/5521997751577?text=Ol%C3%A1%2C%20achei%20voc%C3%AAs%20no%20google%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es!"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center rounded-full bg-green-600 px-10 py-6 text-lg font-bold text-white shadow-xl hover:bg-green-700 hover:scale-105 active:scale-95 transition-all"
            >
              <svg class="mr-3 h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Falar no WhatsApp
            </a>
            <a
              href="/contato"
              class="inline-flex items-center justify-center rounded-full bg-white/10 px-10 py-6 text-lg font-bold text-white ring-1 ring-inset ring-white/20 hover:bg-white/20 hover:scale-105 active:scale-95 transition-all backdrop-blur-sm"
            >
              Solicitar Orçamento
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
