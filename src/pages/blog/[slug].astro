---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_CONFIG } from '../../data/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.slug !== post.slug && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const title = `${post.data.title} | Blog Aluguel de Betoneira`;
const description = post.data.description;

// Tempo de leitura
const wordCount = post.body.split(/\s+/).filter(Boolean).length;
const readingTimeMinutes = Math.ceil(wordCount / 200);
const timeRequired = `PT${readingTimeMinutes}M`;

// Schema BlogPosting
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${SITE_CONFIG.url}/blog/${post.slug}/#post`,
  headline: post.data.title,
  description: post.data.description,
  url: `${SITE_CONFIG.url}/blog/${post.slug}/`,
  image: post.data.image ? `${SITE_CONFIG.url}${post.data.image}` : `${SITE_CONFIG.url}${SITE_CONFIG.ogImage}`,
  author: {
    '@type': 'Organization',
    name: 'Aluguel de Betoneira',
    '@id': `${SITE_CONFIG.url}/#organization`,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${SITE_CONFIG.url}/#organization`,
  },
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.updatedDate?.toISOString() || post.data.pubDate.toISOString(),
  wordCount: wordCount,
  timeRequired: timeRequired,
  articleSection: 'Construção Civil',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': `${SITE_CONFIG.url}/blog/${post.slug}/`,
  },
};

const faqData = {
  'quanto-custa-alugar-betoneira': [
    { name: 'Quanto custa alugar uma betoneira por dia?', text: 'O valor da diária varia conforme a capacidade, começando a partir de R$ 80,00 para modelos de 120 litros.' },
    { name: 'O preço do aluguel de betoneira inclui entrega?', text: 'O valor da locação não inclui o frete de entrega e retirada, que é calculado por distância e informado no orçamento.' },
    { name: 'Posso alugar uma betoneira por apenas um dia?', text: 'Sim, o prazo mínimo é de 1 dia. Locações mais longas têm descontos progressivos.' },
    { name: 'É melhor alugar por diária ou por mês?', text: 'Para obras acima de 15 dias, o aluguel mensal é mais econômico, reduzindo o custo por dia drasticamente.' },
  ],
  'aluguel-betoneira-400-litros-preco': [
    { name: 'Quanto custa o aluguel de betoneira 400 litros?', text: 'O valor da diária para uma betoneira 400 litros começa a partir de R$ 250,00, com descontos para locações semanais e mensais.' },
    { name: 'Quando usar uma betoneira 400 litros?', text: 'Ela é indicada para construções comerciais, usinas de concreto temporárias e grandes reformas que exigem alto volume de produção.' },
    { name: 'É melhor alugar uma 400L ou duas de 200L?', text: 'Se a obra tem um único ponto de concreto, a betoneira 400 litros é mais econômica. Se há dois pontos distantes, duas de 200L podem fazer sentido.' },
    { name: 'O aluguel de betoneira 400 litros inclui entrega?', text: 'Sim, entregamos diretamente na obra, posicionamos o equipamento e fazemos o teste de funcionamento.' },
  ],
  'aluguel-betoneira-150-250-litros-preco': [
    { name: 'Qual a diferença entre betoneira 150 litros e 200 litros?', text: 'A 150L produz até 3 m³/dia e a 200L até 5 m³/dia. A 200L é ideal para obras maiores com custo por m³ mais baixo.' },
    { name: 'Quanto custa alugar uma betoneira 150 litros?', text: 'A diária começa a partir de R$ 100,00, com descontos progressivos para locações semanais e mensais.' },
    { name: 'Posso trocar de modelo durante a locação?', text: 'Sim, é possível fazer upgrade de uma 150L para 200L durante a locação pagando apenas a diferença proporcional.' },
    { name: 'O frete está incluído no preço do aluguel?', text: 'Não. O frete é calculado por distância e informado no orçamento. Zona Norte tem frete reduzido.' },
  ],
  'aluguel-betoneira-mensal': [
    { name: 'Quanto economizo com aluguel mensal vs diário?', text: 'O aluguel mensal pode reduzir o custo por dia em até 50% comparado à locação diária avulsa.' },
    { name: 'Posso cancelar a locação mensal antes do prazo?', text: 'Sim, cobramos apenas o proporcional dos dias usados, sem multa se comunicado com 3 dias de antecedência.' },
    { name: 'O pagamento mensal pode ser parcelado?', text: 'Sim, aceitamos parcelamento em até 3 vezes no cartão. Pagamento à vista tem desconto de 5%.' },
    { name: 'É possível trocar de modelo durante a locação mensal?', text: 'Sim, é possível fazer upgrade ou downgrade sem custo de logística adicional, ajustando o valor proporcionalmente.' },
  ],
  'aluguel-betoneira-perto-de-mim': [
    { name: 'Vocês entregam betoneira no mesmo dia?', text: 'Sim, para zona Norte do Rio entregamos no mesmo dia para solicitações antes das 14h. Outras regiões até 24h.' },
    { name: 'Qual o valor do frete?', text: 'Calculado por distância. Bairros próximos à base têm frete reduzido. Bairros mais distantes podem ter acréscimo proporcional.' },
    { name: 'Posso retirar a betoneira na loja?', text: 'Sim, a retirada na base elimina o custo de frete de entrega, desde que agendada previamente.' },
    { name: 'E se a betoneira quebrar depois da entrega?', text: 'Suporte técnico prioritário para a cidade do Rio de Janeiro. Trocamos o equipamento no mesmo dia se necessário.' },
  ],
};

const faqSchema = faqData[post.slug]
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqData[post.slug].map((q) => ({
        '@type': 'Question',
        name: q.name,
        acceptedAnswer: {
          '@type': 'Answer',
          text: q.text,
        },
      })),
    }
  : null;
---

<Layout
  title={title}
  description={description}
  canonical={`/blog/${post.slug}/`}
  type="article"
  pubDate={post.data.pubDate.toISOString()}
  updatedDate={post.data.updatedDate?.toISOString()}
  schema={blogPostingSchema}
  breadcrumbName={post.data.title}
  preloadHero={false}
>
  <Header currentPath="/blog" />

  {
    faqSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )
  }

  <main>
    <!-- Hero Section -->
    <section class="relative py-24 lg:py-32 bg-gray-900 overflow-hidden">
      <div class="absolute inset-0">
        <img
          src="/images/hero-obra.jpg"
          alt="Betoneira em obra de construção civil no Rio de Janeiro"
          class="h-full w-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
          width="1257"
          height="586"
        />
        <div class="absolute inset-0 bg-gradient-to-br from-[#1A1A1A]/90 via-[#2D2D2D]/85 to-[#4A4A4A]/75"></div>
      </div>

      <div class="relative container mx-auto px-6 sm:px-8 lg:px-12 max-w-5xl">
        <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-gray-100 mb-6">
          <a href="/" class="hover:text-primary transition-colors">Início</a>
          <span>/</span>
          <a href="/blog/" class="hover:text-primary transition-colors">Blog</a>
          <span>/</span>
          <span class="text-white">{post.data.title}</span>
        </nav>

        <h1 class="text-4xl sm:text-5xl font-black text-white leading-tight mb-16">
          {post.data.title}
        </h1>

        <div class="flex flex-wrap items-center gap-4 text-gray-100">
          <div class="flex items-center gap-3">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-gray-900 font-bold text-sm">
              {post.data.author.charAt(0)}
            </div>
            <p class="font-medium text-white">{post.data.author}</p>
          </div>
          <span class="text-gray-500">•</span>
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
          </time>
          <span class="text-gray-500">•</span>
          <span>{readingTimeMinutes} min de leitura</span>
        </div>
      </div>
    </section>

    <!-- Article Content -->
    <section class="py-24 lg:py-32 bg-white">
      <div class="container mx-auto px-6 sm:px-8 lg:px-12 max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
          <div class="lg:col-span-2">
            {post.data.image && (
              <div class="mb-12 rounded-2xl overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-auto object-cover"
                  loading="eager"
                  decoding="async"
                  width="1200"
                  height="675"
                />
              </div>
            )}
            <article class="prose prose-lg prose-gray max-w-none">
              <Content />
            </article>

            <div class="mt-16 pt-8 border-t border-gray-200">
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-gray-100 px-4 py-2 text-sm font-medium text-gray-700">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Sidebar CTA -->
          <div class="lg:col-span-1">
            <div class="sticky top-24 space-y-6">
              <div class="rounded-2xl bg-secondary p-10 text-center shadow-xl transition-all hover:shadow-2xl hover:scale-[1.02]">
                <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/20 text-primary mb-6">
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-3">Precisa de uma betoneira?</h3>
                <p class="text-gray-100 text-sm mb-6">Solicite um orçamento grátis e receba nossa proposta em poucos minutos.</p>
                <a
                  href="/contato/"
                  class="block w-full text-center rounded-full bg-primary px-6 py-4 text-base font-bold text-gray-900 shadow-lg shadow-primary/20 hover:bg-primary-400 hover:scale-105 active:scale-95 transition-all mb-4"
                >
                  Solicitar Orçamento
                </a>
                <a
                  href="https://wa.me/5521997751577?text=Ol%C3%A1%2C%20achei%20voc%C3%AAs%20no%20google%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es!"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="block w-full text-center rounded-full bg-whatsapp px-6 py-4 text-base font-bold text-white shadow-lg shadow-green-600/20 hover:bg-whatsapp-dark hover:scale-105 active:scale-95 transition-all"
                >
                  Falar no WhatsApp
                </a>
              </div>

              <div class="rounded-2xl border border-gray-200 bg-gray-50 p-10 transition-all hover:shadow-md">
                <h4 class="text-lg font-bold text-gray-900 mb-4">Categorias</h4>
                <div class="flex flex-wrap gap-2">
                  <a href="/blog/" class="inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-medium text-gray-700 border border-gray-200 hover:border-secondary hover:text-secondary transition-all hover:scale-105">Dicas de Obra</a>
                  <a href="/blog/" class="inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-medium text-gray-700 border border-gray-200 hover:border-secondary hover:text-secondary transition-all hover:scale-105">Locação</a>
                  <a href="/blog/" class="inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-medium text-gray-700 border border-gray-200 hover:border-secondary hover:text-secondary transition-all hover:scale-105">Equipamentos</a>
                  <a href="/blog/" class="inline-flex items-center rounded-full bg-white px-4 py-2 text-sm font-medium text-gray-700 border border-gray-200 hover:border-secondary hover:text-secondary transition-all hover:scale-105">Segurança</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Outras Dicas de Obra -->
    {relatedPosts.length > 0 && (
      <section class="py-24 lg:py-32 bg-gray-50">
        <div class="container mx-auto px-6 sm:px-8 lg:px-12">
          <div class="max-w-5xl mx-auto">
            <div class="flex items-center justify-between mb-12">
              <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Outras Dicas de Obra</h2>
              <a href="/blog/" class="text-sm font-semibold text-secondary hover:text-secondary-700 transition-colors">Ver todas →</a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
              {relatedPosts.map((related) => (
                <article class="group flex flex-col rounded-2xl border border-gray-200 bg-white overflow-hidden shadow-sm transition-all hover:shadow-lg hover:-translate-y-1 hover:scale-[1.02] reveal">
                  <a href={`/blog/${related.slug}/`} class="flex flex-col h-full">
                    <div class="aspect-[16/9] bg-gray-200 overflow-hidden">
                      {related.data.image ? (
                        <img
                          src={related.data.image}
                          alt={related.data.title}
                          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                          loading="lazy"
                          width="800"
                          height="450"
                        />
                      ) : (
                        <div class="flex h-full w-full items-center justify-center bg-gray-800 text-gray-300">
                          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                            <circle cx="8.5" cy="8.5" r="1.5"/>
                            <polyline points="21 15 16 10 5 21"/>
                          </svg>
                        </div>
                      )}
                    </div>
                    <div class="flex flex-col flex-1 p-8">
                      <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                        <time datetime={related.data.pubDate.toISOString()}>
                          {related.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
                        </time>
                      </div>
                      <h3 class="text-lg font-bold text-gray-900 group-hover:text-secondary transition-colors mb-3">
                        {related.data.title}
                      </h3>
                      <p class="text-sm text-gray-600 flex-1">
                        {related.data.description}
                      </p>
                      <div class="mt-4 inline-flex items-center text-sm font-semibold text-secondary group-hover:text-secondary-700 transition-colors">
                        Ler mais →
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</Layout>
