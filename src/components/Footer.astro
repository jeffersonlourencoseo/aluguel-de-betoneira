---
const currentYear = new Date().getFullYear();

const footerLinks = {
  servicos: [
    { label: "Aluguel de Betoneira 120L", href: "/servicos/betoneira-120l" },
    { label: "Aluguel de Betoneira 150L", href: "/servicos/betoneira-150l" },
    { label: "Aluguel de Betoneira 200L", href: "/servicos/betoneira-200l" },
    { label: "Aluguel de Betoneira 400L", href: "/servicos/betoneira-400l" }
  ],
  empresa: [
    { label: "Quem Somos", href: "/sobre" },
    { label: "Nossos Serviços", href: "/servicos" },
    { label: "Blog", href: "/blog" },
    { label: "Contato", href: "/contato" }
  ],
  suporte: [
    { label: "Perguntas Frequentes", href: "/#faq" },
    { label: "Política de Privacidade", href: "/privacidade" },
    { label: "Termos de Uso", href: "/termos" }
  ]
};
---

<footer class="border-t border-gray-200 bg-gray-50">
  <div class="container mx-auto px-6 sm:px-8 lg:px-12 pt-24 pb-12">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-gray-900 transition-all hover:scale-105 active:scale-95">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-primary text-accent">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </span>
          Aluguel de Betoneira
        </a>
        <p class="text-sm text-gray-600 leading-relaxed">
          Especialistas em locação de betoneiras para construção civil. Entrega rápida, equipamentos revisados e preço justo.
        </p>
      </div>

      <!-- Serviços -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Serviços</h3>
        <ul class="mt-4 space-y-3">
          {footerLinks.servicos.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 hover:text-primary transition-all hover:scale-105 active:scale-95 inline-block">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Empresa</h3>
        <ul class="mt-4 space-y-3">
          {footerLinks.empresa.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 hover:text-primary transition-all hover:scale-105 active:scale-95 inline-block">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Suporte -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-900">Suporte</h3>
        <ul class="mt-4 space-y-3">
          {footerLinks.suporte.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-600 hover:text-primary transition-all hover:scale-105 active:scale-95 inline-block">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-gray-200 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        © {currentYear} Aluguel de Betoneira. Todos os direitos reservados.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://wa.me/5521997751577?text=Ol%C3%A1%2C%20vim%20do%20site%20e%20gostaria%20de%20mais%20informa%C3%A7%C3%B5es!" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-green-600 transition-all hover:scale-110 active:scale-95" aria-label="WhatsApp">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-pink-600 transition-all hover:scale-110 active:scale-95" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
