---
import { SITE_CONFIG } from '../data/config';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  type?: string;
  pubDate?: string;
  updatedDate?: string;
  preloadHero?: boolean;
}

const {
  title,
  description = SITE_CONFIG.description,
  keywords = SITE_CONFIG.keywords,
  canonical = Astro.url.pathname,
  ogImage = SITE_CONFIG.ogImage,
  noindex = false,
  type = 'website',
  pubDate,
  updatedDate,
  preloadHero = true,
} = Astro.props;

function normalizeCanonical(path: string): string {
  if (path === '/') return path;
  return path.endsWith('/') ? path : `${path}/`;
}

const fullTitle = title.includes(SITE_CONFIG.name) ? title : `${title} | ${SITE_CONFIG.name}`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || SITE_CONFIG.url;
const fullCanonical = `${siteUrl}${normalizeCanonical(canonical)}`;
const fullOgImage = `${siteUrl}${ogImage}`;
---

<!-- Charset & Viewport -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#1A1A1A" />

{
  preloadHero && (
    <!-- Preload LCP hero image (local, self-hosted) -->
    <link rel="preload" as="image" href="/images/hero-obra.jpg" fetchpriority="high" />
  )
}

<!-- Primary Meta -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="keywords" content={keywords} />
<meta name="language" content="Portuguese" />
<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />

<!-- Geo / Local SEO -->
<meta name="geo.region" content="BR-RJ" />
<meta name="geo.placename" content={SITE_CONFIG.nap.address.city} />
<meta name="geo.position" content={`${SITE_CONFIG.geo.latitude};${SITE_CONFIG.geo.longitude}`} />
<meta name="ICBM" content={`${SITE_CONFIG.geo.latitude}, ${SITE_CONFIG.geo.longitude}`} />

<!-- Canonical -->
<link rel="canonical" href={fullCanonical} />

<!-- Icons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="alternate" type="application/rss+xml" title={`${SITE_CONFIG.name} - Blog`} href="/rss.xml" />

<!-- Preconnect Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@400;500;600;700&display=swap"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@400;500;600;700&display=swap" />
</noscript>

<!-- Open Graph — Facebook / WhatsApp / LinkedIn -->
<meta property="og:type" content={type} />
{
  type === 'article' && (
    <>
      {pubDate && <meta property="article:published_time" content={pubDate} />}
      {updatedDate && <meta property="article:modified_time" content={updatedDate} />}
      <meta property="article:author" content="Aluguel de Betoneira" />
      <meta property="article:section" content="Construção Civil" />
    </>
  )
}
<meta property="og:site_name" content={SITE_CONFIG.name} />
<meta property="og:locale" content="pt_BR" />
<meta property="og:url" content={fullCanonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={fullTitle} />

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@aluguelbetoneira" />
<meta name="twitter:url" content={fullCanonical} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullOgImage} />
<meta name="twitter:image:alt" content={fullTitle} />
