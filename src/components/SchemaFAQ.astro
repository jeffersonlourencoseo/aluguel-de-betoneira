---
export interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  id?: string;
}

const { items, id = '#faq' } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${Astro.url.origin}${Astro.url.pathname}${id}`,
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
