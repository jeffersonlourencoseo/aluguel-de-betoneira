---
import { SITE_CONFIG } from '../data/config';

interface Props {
  servicos?: Array<{ title: string; slug?: string }>;
  pageType?: 'home' | 'about' | 'contact' | 'service' | 'blog';
  breadcrumbName?: string;
}

const { servicos = [], breadcrumbName } = Astro.props;

const address = SITE_CONFIG.nap.address;
const pathname = Astro.url.pathname;

// Mesmo sem Google Business Profile ou Instagram, mantemos o array vazio
// para que o schema Organization continue válido e extensível no futuro.
const sameAs: string[] = [];

const googleMapsEmbedUrl = `https://www.google.com/maps?q=${SITE_CONFIG.geo.latitude},${SITE_CONFIG.geo.longitude}`;

// Breadcrumb dinâmico baseado no pathname
function buildBreadcrumbItems() {
  const items: Array<{ name: string; item?: string }> = [
    { name: 'Início', item: SITE_CONFIG.url },
  ];

  if (pathname === '/' || pathname === '') return items;

  const segments = pathname.split('/').filter(Boolean);

  if (segments[0] === 'sobre') {
    items.push({ name: 'Quem Somos' });
  } else if (segments[0] === 'contato') {
    items.push({ name: 'Contato' });
  } else if (segments[0] === 'servicos') {
    items.push({ name: 'Serviços', item: `${SITE_CONFIG.url}/servicos/` });
    if (segments[1] && breadcrumbName) {
      items.push({ name: breadcrumbName });
    } else if (segments[1]) {
      items.push({ name: 'Detalhes do Serviço' });
    }
  } else if (segments[0] === 'blog') {
    items.push({ name: 'Blog', item: `${SITE_CONFIG.url}/blog/` });
    if (segments[1] && breadcrumbName) {
      items.push({ name: breadcrumbName });
    } else if (segments[1]) {
      items.push({ name: 'Artigo' });
    }
  } else if (segments[0] === 'privacidade') {
    items.push({ name: 'Privacidade' });
  } else if (segments[0] === 'termos') {
    items.push({ name: 'Termos' });
  } else if (segments[0] === 'calculadora-de-concreto') {
    items.push({ name: 'Calculadora de Concreto' });
  }

  return items;
}

const breadcrumbItems = buildBreadcrumbItems();

// LocalBusiness Schema (obrigatório para SEO Local)
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE_CONFIG.url}/#localbusiness`,
  name: SITE_CONFIG.nap.name,
  description: SITE_CONFIG.description,
  url: SITE_CONFIG.url,
  telephone: `+55${SITE_CONFIG.nap.phoneRaw}`,
  email: SITE_CONFIG.nap.email,
  priceRange: SITE_CONFIG.priceRange,
  image: `${SITE_CONFIG.url}${SITE_CONFIG.ogImage}`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: address.street,
    addressLocality: address.city,
    addressRegion: address.state,
    postalCode: address.zip,
    addressCountry: address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE_CONFIG.geo.latitude,
    longitude: SITE_CONFIG.geo.longitude,
  },
  openingHoursSpecification: SITE_CONFIG.openingHours.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.days,
    opens: h.opens,
    closes: h.closes,
  })),
  areaServed: {
    '@type': 'Place',
    name: SITE_CONFIG.areaServed,
    containsPlace: SITE_CONFIG.areaServedCities.map((city) => ({
      '@type': 'City',
      name: city,
      containedInPlace: {
        '@type': 'State',
        name: 'Rio de Janeiro',
      },
    })),
  },
  serviceType: 'Locação de Betoneiras',
  hasMap: googleMapsEmbedUrl,
  foundingDate: SITE_CONFIG.founded,
  hasOfferCatalog: servicos.length > 0
    ? {
        '@type': 'OfferCatalog',
        name: 'Locação de Betoneiras',
        itemListElement: servicos.map((s, i) => ({
          '@type': 'Offer',
          position: i + 1,
          itemOffered: s.slug
            ? {
                '@type': 'Product',
                '@id': `${SITE_CONFIG.url}/servicos/${s.slug}/#product`,
                name: s.title,
              }
            : { '@type': 'Service', name: s.title },
        })),
      }
    : undefined,
};

// WebSite Schema (sem SearchAction: blog não possui página de busca real)
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_CONFIG.url}/#website`,
  name: SITE_CONFIG.name,
  url: SITE_CONFIG.url,
};

// Organization Schema (logo + sameAs redes sociais)
const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_CONFIG.url}/#organization`,
  name: SITE_CONFIG.nap.name,
  url: SITE_CONFIG.url,
  logo: `${SITE_CONFIG.url}/images/logo.svg`,
  sameAs,
  foundingDate: SITE_CONFIG.founded,
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: `+55${SITE_CONFIG.nap.phoneRaw}`,
      contactType: 'customer service',
      contactOption: 'WhatsApp',
      availableLanguage: 'Portuguese',
      areaServed: 'BR',
    },
    {
      '@type': 'ContactPoint',
      telephone: `+55${SITE_CONFIG.nap.phoneRaw}`,
      contactType: 'sales',
      availableLanguage: 'Portuguese',
      areaServed: 'BR',
    },
  ],
};

// BreadcrumbList Schema (dinâmico)
const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    ...(item.item ? { item: item.item } : {}),
  })),
};

const schemas = [localBusiness, website, organization, breadcrumbs].filter(Boolean);
---

{
  schemas.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
