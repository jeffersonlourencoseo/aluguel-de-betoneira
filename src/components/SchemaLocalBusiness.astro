---
import { SITE_CONFIG } from '../data/config';

interface Props {
  servicos?: Array<{ title: string }>;
  pageType?: 'home' | 'about' | 'contact' | 'service' | 'blog';
  breadcrumbName?: string;
}

const { servicos = [], breadcrumbName } = Astro.props;

const address = SITE_CONFIG.nap.address;
const pathname = Astro.url.pathname;

// Breadcrumb dinâmico baseado no pathname
function buildBreadcrumbItems() {
  const items: Array<{ name: string; item?: string }> = [
    { name: 'Início', item: SITE_CONFIG.url },
  ];

  if (pathname === '/' || pathname === '') return items;

  const segments = pathname.split('/').filter(Boolean);

  if (segments[0] === 'sobre') {
    items.push({ name: 'Quem Somos' });
  } else if (segments[0] === 'contato') {
    items.push({ name: 'Contato' });
  } else if (segments[0] === 'servicos') {
    items.push({ name: 'Serviços', item: `${SITE_CONFIG.url}/servicos` });
    if (segments[1] && breadcrumbName) {
      items.push({ name: breadcrumbName });
    } else if (segments[1]) {
      items.push({ name: 'Detalhes do Serviço' });
    }
  } else if (segments[0] === 'blog') {
    items.push({ name: 'Blog', item: `${SITE_CONFIG.url}/blog` });
    if (segments[1] && breadcrumbName) {
      items.push({ name: breadcrumbName });
    } else if (segments[1]) {
      items.push({ name: 'Artigo' });
    }
  } else if (segments[0] === 'privacidade') {
    items.push({ name: 'Privacidade' });
  } else if (segments[0] === 'termos') {
    items.push({ name: 'Termos' });
  }

  return items;
}

const breadcrumbItems = buildBreadcrumbItems();

// LocalBusiness Schema (obrigatório para Google Maps / Painel de Conhecimento)
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE_CONFIG.url}/#localbusiness`,
  name: SITE_CONFIG.nap.name,
  description: SITE_CONFIG.description,
  url: SITE_CONFIG.url,
  telephone: SITE_CONFIG.nap.phone,
  email: SITE_CONFIG.nap.email,
  priceRange: SITE_CONFIG.priceRange,
  image: `${SITE_CONFIG.url}${SITE_CONFIG.ogImage}`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: address.street,
    addressLocality: address.city,
    addressRegion: address.state,
    postalCode: address.zip,
    addressCountry: address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: SITE_CONFIG.geo.latitude,
    longitude: SITE_CONFIG.geo.longitude,
  },
  openingHoursSpecification: SITE_CONFIG.openingHours.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.days,
    opens: h.opens,
    closes: h.closes,
  })),
  areaServed: {
    '@type': 'Place',
    name: SITE_CONFIG.areaServed,
  },
  serviceType: 'Locação de Betoneiras',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5',
    bestRating: '5',
    reviewCount: '3',
  },
  review: [
    {
      '@type': 'Review',
      author: {
        '@type': 'Person',
        name: 'Carlos Eduardo Silva',
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
      },
      reviewBody: 'Já aluguei betoneira aqui mais de 10 vezes. A entrega é sempre pontual e o equipamento chega limpo e funcionando perfeitamente. Recomendo de olhos fechados.',
      datePublished: '2024-03-15',
    },
    {
      '@type': 'Review',
      author: {
        '@type': 'Person',
        name: 'Mariana Oliveira',
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
      },
      reviewBody: 'Como engenheira, preciso de equipamentos confiáveis. A qualidade das betoneiras e o suporte técnico da equipe me deram total segurança para indicar aos meus clientes.',
      datePublished: '2024-04-10',
    },
    {
      '@type': 'Review',
      author: {
        '@type': 'Person',
        name: 'Roberto Mendes',
      },
      reviewRating: {
        '@type': 'Rating',
        ratingValue: '5',
        bestRating: '5',
      },
      reviewBody: 'O atendimento pelo WhatsApp é rápido e o preço é justo. A betoneira 150L atendeu minha obra de 3 meses sem nenhum problema.',
      datePublished: '2024-05-01',
    },
  ],
  hasOfferCatalog: servicos.length > 0
    ? {
        '@type': 'OfferCatalog',
        name: 'Serviços de Locação',
        itemListElement: servicos.map((s, i) => ({
          '@type': 'Offer',
          position: i + 1,
          itemOffered: { '@type': 'Service', name: s.title },
        })),
      }
    : undefined,
};

// WebSite Schema (SearchAction para Sitelinks Searchbox)
const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_CONFIG.url}/#website`,
  name: SITE_CONFIG.name,
  url: SITE_CONFIG.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_CONFIG.url}/busca?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

// Organization Schema (logo + sameAs redes sociais)
const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_CONFIG.url}/#organization`,
  name: SITE_CONFIG.nap.name,
  url: SITE_CONFIG.url,
  logo: `${SITE_CONFIG.url}/images/logo.svg`,
  sameAs: [SITE_CONFIG.social.whatsapp, SITE_CONFIG.social.instagram].filter(Boolean),
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: SITE_CONFIG.nap.phone,
    contactType: 'customer service',
    availableLanguage: 'Portuguese',
    areaServed: 'BR',
  },
};

// BreadcrumbList Schema (dinâmico)
const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    ...(item.item ? { item: item.item } : {}),
  })),
};

const schemas = [localBusiness, website, organization, breadcrumbs].filter(Boolean);
---

{
  schemas.map((schema) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))
}
