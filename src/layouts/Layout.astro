---
import SEO from '../components/SEO.astro';
import SchemaLocalBusiness from '../components/SchemaLocalBusiness.astro';
import WhatsAppBtn from '../components/WhatsAppBtn.astro';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object;
  servicos?: Array<{ title: string }>;
  breadcrumbName?: string;
  type?: string;
  pubDate?: string;
  updatedDate?: string;
}

const { title, description, keywords, canonical, ogImage, noindex, schema, servicos, breadcrumbName, type, pubDate, updatedDate } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <SEO
      title={title}
      description={description}
      keywords={keywords}
      canonical={canonical}
      ogImage={ogImage}
      noindex={noindex}
      type={type}
      pubDate={pubDate}
      updatedDate={updatedDate}
    />

    <!-- Schema.org JSON-LD — LocalBusiness + WebSite + Organization -->
    <SchemaLocalBusiness servicos={servicos} breadcrumbName={breadcrumbName} />

    <!-- Schema adicional por página (opcional) -->
    {
      schema && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
      )
    }

    <!-- Google Tag Manager (via Partytown para não bloquear render) -->
    <script is:inline type="text/partytown">
      (function(w,d,s,l,i){
        w[l]=w[l]||[];
        w[l].push({'gtm.start': new Date().getTime(), event:'gtm.js'});
        var f=d.getElementsByTagName(s)[0], j=d.createElement(s), dl=l!='dataLayer'?'&l='+l:'';
        j.async=true;
        j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
        f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-TZBXS6HT');
    </script>
  </head>

  <body class="font-sans antialiased text-gray-900 bg-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TZBXS6HT" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <slot />
    <WhatsAppBtn />

    <script is:inline>
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        var obs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var d = parseInt(el.dataset.stagger || '0', 10) * 100;
              setTimeout(function () { el.classList.add('is-visible'); }, d);
              obs.unobserve(el);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(function (el) { obs.observe(el); });
      })();
    </script>
  </body>
</html>
